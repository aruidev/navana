{
    "name": "alex/navana",
    "autoload": {
        "psr-4": {
            "Alex\\Navana\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Alex Ruiz",
            "email": "a.ruiz7@sapalomera.cat"
        }
    ],
    "require": {
        "phpmailer/phpmailer": "^7.0",
        "google/apiclient": "^2.19",
        "hybridauth/hybridauth": "^3.12"
    },
    "config": {},
    "scripts": {
        "post-install-cmd": [
            "php -r \"@mkdir('phar/phpdoc', 0777, true); if(!file_exists('phar/phpdoc/phpDocumentor.phar')) { file_put_contents('phar/phpdoc/phpDocumentor.phar', file_get_contents('https://phpdoc.org/phpDocumentor.phar')); }\""
        ],
        "docs": "php phar/phpdoc/phpDocumentor.phar -c phpdoc.dist.xml",
        "fix": "./vendor/bin/php-cs-fixer fix"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94"
    }
}
